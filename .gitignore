.vercel
.env*
node_modules

# Local Claude Code settings (contains Bash allowlist entries with
# real credentials from past debugging sessions) -- never commit
.claude/settings.local.json

# Installed skill packages (third-party tooling cloned via `npx skills
# add`, not part of this website) -- not project source
.agents/
.claude/skills/
skills-lock.json

# Raw reference images pasted into chat during design work (diamond/wall
# color sampling, etc.) -- scratch inputs for a past session, not real site
# assets. The actual deployed images live under assets/.
.claude/*.png
.claude/*.jpeg
.claude/*.jpg
